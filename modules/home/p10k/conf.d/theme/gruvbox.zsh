# ============================================================
# Gruvbox Theme Palette
# ============================================================
https://github.com/morhetz/gruvbox

# Base
local -r C_DARK=235
local -r C_WHITE=223
local -r C_BLACK=0

# Primary
local -r C_PRIMARY=142
local -r C_ACCENT=214

# Semantic
local -r C_SUCCESS=108
local -r C_SUCCESS_ALT=109
local -r C_WARNING=208
local -r C_ERROR=167
local -r C_LANG_WARM=166

# VCS foreground (on top of semantic background colors)
typeset -g C_VCS_CLEAN_FG=0
typeset -g C_VCS_MODIFIED_FG=255
typeset -g C_VCS_UNTRACKED_FG=255
typeset -g C_VCS_CONFLICTED_FG=255
