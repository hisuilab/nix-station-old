# =============================================================================
# Ghostty Config
# =============================================================================

# -----------------------------------------------------------------------------
# Style
# -----------------------------------------------------------------------------
background-opacity = 0.7
theme = Kanagawa Wave
font-family = MesloLGL Nerd Font
font-size = 16
window-padding-x = 8
window-padding-y = 8
cursor-style-blink = false

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden

# Use left Option (⌥) as Alt
macos-option-as-alt = left

# -----------------------------------------------------------------------------
# Behavior
# -----------------------------------------------------------------------------

# Open new tabs/splits in the current working directory
working-directory = inherit

# Copy selected text directly to clipboard
copy-on-select = clipboard

# -----------------------------------------------------------------------------
# Keybinds
# -----------------------------------------------------------------------------
# Show effective keybindings:
#   ghostty +list-keybinds
#
# Modifier keys:
#   super = Command (⌘) on macOS / Super(Windows key) on Linux
#   alt   = Option  (⌥) on macOS / Alt on Linux
#   ctrl  = Control (⌃)
#   shift = Shift   (⇧)
#
# Useful built-in shortcuts:
#   Cmd+Shift+P  Command Palette
#   Cmd+K        Clear Screen
#   Cmd+F        Search Scrollback
#   Cmd+[ / ]    Previous / Next Split

# Fullscreen
keybind = super+enter=toggle_fullscreen

# Quick terminal
keybind = global:ctrl+enter=toggle_quick_terminal

# Split panes
keybind = alt+enter=new_split:right
keybind = alt+shift+enter=new_split:down

# Move between splits
keybind = alt+left=goto_split:left
keybind = alt+right=goto_split:right
keybind = alt+up=goto_split:top
keybind = alt+down=goto_split:bottom

# Resize splits
keybind = alt+shift+left=resize_split:left,10
keybind = alt+shift+right=resize_split:right,10
keybind = alt+shift+up=resize_split:up,10
keybind = alt+shift+down=resize_split:down,10

# -----------------------------------------------------------------------------
# Custom
# -----------------------------------------------------------------------------
initial-window = false
quit-after-last-window-closed = false