# style
background-opacity = 0.7
theme = Kanagawa Wave
font-size = 16
window-padding-x = 8
window-padding-y = 8
cursor-style-blink = false

# macos
macos-titlebar-style = tabs
macos-titlebar-proxy-icon = hidden

# keybind
keybind = global:ctrl+enter=toggle_quick_terminal

keybind = cmd+shift+enter=new_split:down
keybind = cmd+enter=new_split:right

keybind = cmd+left=goto_split:left
keybind = cmd+right=goto_split:right
keybind = cmd+up=goto_split:top
keybind = cmd+down=goto_split:bottom

# custom
initial-window = false
quit-after-last-window-closed = false