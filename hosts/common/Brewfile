# 全ホスト共通 Brewfile
# GUI アプリと App Store アプリを管理する。
# CLI ツールは Home Manager (nix) で管理するため、ここには含めない。
#
# 適用: brew bundle --file hosts/common/Brewfile
#       brew bundle --file hosts/<host-id>/Brewfile  # ホスト固有差分
# 削除: brew bundle cleanup --file hosts/common/Brewfile
#       brew bundle cleanup --file hosts/<host-id>/Brewfile

brew "mas"

# ブラウザ・クラウド
cask "google-chrome"
cask "google-drive"

# ネットワーク・リモートアクセス
cask "tailscale-app"
cask "windows-app"

# 開発エディタ・ターミナル
cask "ghostty"
cask "zed"
cask "visual-studio-code"
cask "codex-app"

# コンテナ
cask "docker-desktop"

# 入力デバイス
cask "karabiner-elements"
cask "logi-options+"

# コミュニケーション
cask "slack"
cask "discord"
cask "linear"
cask "zoom"

# クリエイティブ
cask "affinity"

# ユーティリティ
cask "raycast"
cask "keycastr"

# フォント
cask "font-meslo-lg-nerd-font"

# App Store アプリ（全ホスト共通）
mas "RunCat", id: 1429033973
